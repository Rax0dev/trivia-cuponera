# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=xxxxxxxxxx

# Optional API key to protect /api/notify from abuse.
# Leave empty to disable the check.
NOTIFY_API_KEY=xxxxxxxxxxxxxxxx

# Allowed origins for CORS (production and development)
ALLOWED_ORIGINS=https://trivia-cuponera.vercel.app,http://localhost:5173

# Rate limiting: max notifications per IP per time window
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# Frontend - must match NOTIFY_API_KEY if you enabled it
VITE_NOTIFY_API_KEY=xxxxxxxxxxxxxxxx
